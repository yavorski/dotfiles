{
  "height": 34,
  "layer": "top",
  "position": "top",
  "exclusive": true,
  "no-center": true,
  "fixed-center": false,
  "reload_style_on_change": false,

  "modules-left": [
    "hyprland/workspaces",
    "hyprland/submap",
    "hyprland/window#app-id",
    "hyprland/window#app-title"
  ],
  "modules-center": [],
  "modules-right": [
    "hyprland/workspaces#scratchpad",
    "systemd-failed-units",
    "privacy",
    "custom/pacman",
    "cpu",
    "memory",
    "disk",
    "disk#disk-home",
    "temperature",
    "backlight",
    "power-profiles-daemon",
    "idle_inhibitor",
    "pulseaudio",
    "network",
    "battery",
    "clock",
    "hyprland/language",
    "custom/notify",
    "tray"
  ],

  // workspaces
  "hyprland/workspaces": {
    "all-outputs": true,
    "disable-scroll": true,
    "format": "{id}",
    "format-icons": {
      "active": "ÔĆÉ"
    }
  },

  // special/scratchpad workspace
  "hyprland/workspaces#scratchpad": {
    "all-outputs": true,
    "active-only": true,
    "show-special": true,
    "disable-scroll": true,
    "special-visible-only": true,
    "ignore-workspaces": ["\\d+$"]
  },

  // window id/class
  "hyprland/window#app-id": {
    "icon": false,
    "format": "[ {class} ]"
  },

  // window title
  "hyprland/window#app-title": {
    "icon": false,
    "format": "{title}",
    "rewrite": {
      "(.*) - mpv": "$1",
      "(.*) - Brave": "$1",
      "(.*) - Chromium": "$1",
      "(.*) ‚ÄĒ Mozilla Firefox": "$1",
      "(.*) - VLC media player": "$1"
    }
  },

  // mode move/resize
  "hyprland/submap": {
    "format": "[ {} ]",
    "tooltip": true,
    "always-on": false
  },

  // system updates
  "custom/pacman": {
    "signal": 8,
    "format": "[ {} ‚Ė≤ ]",
    "tooltip": false,
    "interval": 3600, // seconds
    "exec": "checkupdates --nosync --nocolor | wc --lines",
    "exec-if": "checkupdates",
    "on-click": "pkill -SIGRTMIN+8 waybar"
  },

  "cpu": {
    "tooltip": true,
    "format": "{usage}% Ôíľ", // Ôíľ Ôčõ
    "states": {
      "good": 16,
      "warning": 32,
      "critical": 64
    }
  },

  "memory": {
    "tooltip": true,
    "format": "{percentage}% ÔĒł {swapPercentage}% ÔĒł",
    "tooltip-format": " {percentage}% ÔĒł memory {used}GB / {total}GB \n {swapPercentage}% ÔÉČ swap {swapUsed}GB / {swapAvail}GB ",
    "states": {
      "good": 25,
      "warning": 50,
      "critical": 75
    }
  },

  "disk": {
    "path": "/",
    "interval": 1024,
    "format": "{percentage_used}% Ôā†",
    "states": {
      "critical": 50
    }
  },

  "disk#disk-home": {
    "path": "/home",
    "disk": "disk-home",
    "interval": 1024,
    "format": "{percentage_used}% Ôā†",
    "states": {
      "critical": 50
    }
  },

  "temperature": {
    "tooltip": true,
    "critical-threshold": 55,
    "format": "[‚ÄČ{temperatureC}¬į‚ÄČ]", // thin space
    "tooltip-format": "Temperature {temperatureC}¬įC"
  },

  // display brightness
  "backlight": {
    "format": "[‚ÄČ{percent}<sup>‚ÄČÔĄÜ</sup>‚ÄČ]", // thin space
    "tooltip-format": "Backlight {percent}%"
  },

  "pulseaudio": {
    "max-volume": 100,
    "scroll-step": 1.0,
    "format": "{volume}% {icon} {format_source}",
    "format-muted": "[ ůįĚü ] {format_source}",
    "format-source": "[‚ÄČůįćĮ‚ÄČ]",
    "format-source-muted": "[‚ÄČ‚ÄČ<small>ůįć≠</small>‚ÄČ‚ÄČ]",
    "format-bluetooth": "[‚ÄČÔäĒ‚ÄČ]",
    "format-bluetooth-muted": "[‚ÄČ‚ÄČ<small>ůįā≤</small>‚ÄČ‚ÄČ]",
    "format-icons": {
      "car": "ÔÜĻ",
      "phone": "Ôāē",
      "portable": "Ôāē",
      "headset": "ÔĖź",
      "headphone": "ÔÄ•",
      "hands-free": "ÔĖź",
      "default": [ "ÔÄ¶", "ÔÄß", "ÔÄ®" ]
    },
    // "on-click": "pavucontrol",
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
  },

  "battery": {
    "states": {
      "full": 100,
      "good": 80,
      "warning": 25,
      "critical": 20
    },
    "format": "{capacity}% {icon}",
    "format-alt": "[ {time} {icon} ]",
    "format-plugged": "{capacity}% Ôá¶",
    "format-charging": "{capacity}% Ôóß",
    "format-icons": ["ÔČĄ", "ÔČÉ", "ÔČā", "ÔČĀ", "ÔČÄ"],
    "tooltip-format": " {timeTo} \n {power}W / {cycles} cycles / {health}% health",
    "on-update": "/usr/local/bin/battery-notify.sh"
  },

  "network": {
    "format-wifi": "{essid}",
    "format-linked": "[ {ifname} (No IP) ÔěĖ ]",
    "format-ethernet": "[ {ifname}: {ipaddr}/{cidr} ÔěĖ ]",
    "format-disconnected": "[ Disconnected ‚ö† ]",
    "format-alt": "[ {ifname}: {ipaddr}/{cidr} ]",
    "tooltip-format-wifi": "{essid} [ {signalStrength}% ] Ôáę"
  },

  "clock": {
    "format": "{:%H:%M}",
    "format-alt": "[ {:%d.%m.%Y} ]",
    "tooltip-format": "<tt>{calendar}</tt>",
    "actions": { "on-click-right": "mode" },
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "format": {
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>",
        "weekdays": "<span color='#99ffdd'><b>{}</b></span>"
      }
    }
  },

  "hyprland/language": {
    "format": "{}",
    "format-en": "ūüáļūüáł",
    "format-bg": "ūüáßūüá¨"
  },

  // hidden if no apps in tray
  "tray": {
    "spacing": 10,
    "icon-size": 16
  },

  "custom/arch": {
    "format": "ÔĆÉ"
  },

  "custom/right-arrow": {
    "format": " ÔÉö "
  },

  "systemd-failed-units": {
    "user": true,
    "system": true,
    "hide-on-ok": true,
    "format-ok": "[ ‚úď ]",
    "format": "[ {nr_failed}<sup>‚úó</sup> ]"
  },

  // lock/unlocked
  "idle_inhibitor": {
    "format": "[‚ÄČ‚ÄČ{icon}‚ÄČ‚ÄČ]", // thin space
    "format-icons": {
      "activated": "ÔĄ†",
      "deactivated": "<small>Ô†ĺ</small>"
    }
  },

  "power-profiles-daemon": {
    "format": "[‚ÄČ‚ÄČ{icon}‚ÄČ‚ÄČ]", // thin space
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "Ó¨ļ",
      "performance": "+",
      "balanced": "=",
      "power-saver": "-"
    }
  },

  "custom/notify": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "ÔĆÉ",
      "none": "ÔĆÉ",
      "dnd-notification": "ÔĆÉ",
      "dnd-none": "ÔĆÉ",
      "inhibited-notification": "ÔĆÉ",
      "inhibited-none": "ÔĆÉ",
      "dnd-inhibited-notification": "ÔĆÉ",
      "dnd-inhibited-none": "ÔĆÉ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client --subscribe-waybar",
    "on-click": "swaync-client --toggle-panel --skip-wait",
    "on-click-right": "swaync-client --toggle-dnd --skip-wait",
    "escape": true
  }
}
