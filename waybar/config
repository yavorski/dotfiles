{
  "height": 34,
  "layer": "top",
  "position": "top",
  "fixed-center": false,
  "reload_style_on_change": false,

  "modules-left": [
    // "sway/workspaces",
    // "sway/mode",
    // "sway/window#app-id",
    // "sway/window#app-title",
    "hyprland/workspaces",
    "hyprland/submap",
    "hyprland/window#app-id",
    "hyprland/window#app-title"
  ],
  "modules-center": [],
  "modules-right": [
    "hyprland/workspaces#scratchpad",
    "systemd-failed-units",
    "privacy",
    "custom/pacman",
    "idle_inhibitor",
    "cpu",
    "memory",
    "disk",
    "disk#disk-home",
    "temperature",
    "backlight",
    "pulseaudio",
    // "sway/scratchpad#count",
    // "sway/scratchpad#icon",
    "power-profiles-daemon",
    "battery",
    "network",
    "clock",
    // "sway/language",
    "hyprland/language",
    "custom/notify",
    "tray"
  ],

  // workspace buttons
  "hyprland/workspaces": {
    "all-outputs": true,
    "disable-scroll": true,
    "format": "{icon}",
    "format-icons": {
      "active": ""
    }
  },

  "hyprland/workspaces#scratchpad": {
    "all-outputs": true,
    "active-only": true,
    "show-special": true,
    "disable-scroll": true,
    "special-visible-only": true,
    "ignore-workspaces": ["\\d+$"]
  },

  // workspace buttons
  "sway/workspaces": {
    "all-outputs": true,
    "disable-scroll": true,
    "format": "{icon}",
    "format-icons": {
      "focused": ""
    }
  },

  "sway/window#app-id": {
    "icon": false,
    "format": "[ {app_id} ]"
  },

  "sway/window#app-title": {
    "icon": false,
    "format": "{title}",
    "rewrite": {
      "(.*) - Chromium": "$1",
      "(.*) — Mozilla Firefox": "$1",
      "(.*) - VLC media player": "$1"
    }
  },

  "hyprland/window#app-id": {
    "icon": false,
    "format": "[ {class} ]"
  },

  "hyprland/window#app-title": {
    "icon": false,
    "format": "{title}",
    "rewrite": {
      "(.*) - Chromium": "$1",
      "(.*) — Mozilla Firefox": "$1",
      "(.*) - VLC media player": "$1"
    }
  },

  // sway mode - resize, default, etc
  "sway/mode": {
    "format": "{}"
  },

  "hyprland/submap": {
    "format": "[ {} ]",
    "tooltip": true,
    "always-on": false
  },

  // system updates
  "custom/pacman": {
    "signal": 8,
    "format": "[ {} ▲ ]",
    "interval": 3600, // seconds
    "exec": "checkupdates | wc --lines",
    "exec-if": "checkupdates"
  },

  // lock/unlocked
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "",
      "deactivated": ""
    }
  },

  "cpu": {
    "tooltip": true,
    "format": "{usage}% ",
    "states": {
      "good": 16,
      "warning": 32,
      "critical": 64
    }
  },

  "memory": {
    "tooltip": true,
    "format": "{percentage}%  {swapPercentage}% ",
    "tooltip-format": "{percentage}%  memory {used}GB / {total}GB \n{swapPercentage}%  swap {swapUsed}GB / {swapAvail}GB",
    "states": {
      "good": 32,
      "warning": 64,
      "critical": 80
    }
  },

  "disk": {
    "path": "/",
    "interval": 1024,
    "format": "{percentage_used}% ",
    "states": {
      "critical": 75
    }
  },

  "disk#disk-home": {
    "path": "/home",
    "disk": "disk-home",
    "interval": 1024,
    "format": "{percentage_used}% ",
    "states": {
      "critical": 75
    }
  },

  "temperature": {
    "tooltip": true,
    "critical-threshold": 55,
    "format": "{temperatureC}°"
  },

  // display brightness
  "backlight": {
    "format": "{percent}<sup> </sup>"
  },

  "pulseaudio": {
    "max-volume": 100,
    "scroll-step": 5.0,
    "on-click": "pavucontrol",
    "format": "{volume}% {icon} {format_source}",
    "format-muted": "[  ] {format_source}",
    "format-source": "{volume}% ",
    "format-source-muted": "[  ]",
    "format-bluetooth": "{volume}% {icon} {format_source}",
    "format-bluetooth-muted": " {icon} {format_source}",
    "format-icons": {
      "headphone": "",
      "hands-free": "",
      "headset": "",
      "phone": "",
      "portable": "",
      "car": "",
      "default": ["", "", ""]
    }
  },

  "sway/scratchpad#count": {
    "tooltip": true,
    "show-empty": false,
    "format": "{count}",
    "tooltip-format": "[ {app} ] {title}"
  },

  "sway/scratchpad#icon": {
    "tooltip": true,
    "show-empty": true,
    "format": "{icon}",
    "format-icons": ["", ""], // empty, non-empty icon
    "tooltip-format": "[ {app} ] {title}"
  },

  "battery": {
    "states": {
      "good": 80,
      "warning": 30,
      "critical": 20
    },
    "format": "{capacity}% {icon}",
    "format-alt": "[ {time} {icon} ]",
    "format-plugged": "{capacity}% ",
    "format-charging": "{capacity}% ",
    "format-icons": ["", "", "", "", ""]
  },

  "network": {
    // "interface": "wlp2*", // (Optional) To force the use of this interface
    "format-wifi": "{essid}  ",
    "format-ethernet": "{ifname}: {ipaddr}/{cidr} ",
    "format-linked": "{ifname} (No IP) ",
    "format-disconnected": "Disconnected ⚠",
    "format-alt": "{ifname}: {ipaddr}/{cidr} ",
    "tooltip-format-wifi": "{essid} [ {signalStrength}% ] "
  },

  "clock": {
    "format": "{:%H:%M}",
    "format-alt": "{:%d.%m.%Y}",
    "tooltip-format": "<tt>{calendar}</tt>",
    "calendar": {
      "mode": "month",
      "format": {
        "today": "<span color='#ff6699'><b>{}</b></span>",
        "weekdays": "<span color='#99ffdd'><b>{}</b></span>"
      }
    }
  },

  "hyprland/language": {
    "format": "{}",
    "format-en": "🇺🇸",
    "format-bg": "🇧🇬"
  },

  "sway/language": {
    "tooltip": true,
    "format": "{flag}",
    "tooltip-format": "{flag} {long}",
    "on-click": "swaymsg input type:keyboard xkb_switch_layout next"
  },

  // hidden if no apps in tray
  "tray": {
    "spacing": 10,
    "icon-size": 16
  },

  "custom/arch": {
    "format": ""
  },

  "custom/right-arrow": {
    "format": "  "
  },

  "systemd-failed-units": {
    "user": true,
    "system": true,
    "hide-on-ok": true,
    "format-ok": "[ ✓ ]",
    "format": "[ {nr_failed}<sup>✗</sup> ]",
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "",
      "performance": "",
      "balanced": "",
      "power-saver": ""
    }
  },

  "custom/notify": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "<span color='#fa005f'><sup></sup></span>",
      "none": "<span color='#000000'><sup></sup></span>",
      "dnd-notification": "<span color='#fafafa'><sup></sup></span>",
      "dnd-none": "<span color='#000000'><sup></sup></span>",
      "inhibited-notification": "<span color='#fafafa'><sup></sup></span>",
      "inhibited-none": "<span color='#000000'><sup></sup></span>",
      "dnd-inhibited-notification": "<span color='#fafafa'><sup></sup></span>",
      "dnd-inhibited-none": "<span color='#000000'><sup></sup></span>"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client --subscribe-waybar",
    "on-click": "swaync-client --toggle-panel --skip-wait",
    "on-click-right": "swaync-client --toggle-dnd --skip-wait",
    "escape": true
  }
}
