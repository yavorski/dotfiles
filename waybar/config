{
  "height": 30,
  "layer": "top",
  "position": "top",

  // order modules
  "modules-left": [
    "sway/workspaces",
    "sway/mode",
    "sway/window#app-id",
    "sway/window#app-title"
  ],
  "modules-center": [],
  "modules-right": [
    "custom/pacman",
    "idle_inhibitor",
    "cpu",
    "memory",
    "disk",
    "disk#disk-home",
    "temperature",
    "backlight",
    "pulseaudio",
    "sway/scratchpad#count",
    "sway/scratchpad#icon",
    "battery",
    "network",
    "clock",
    "sway/language",
    "tray"
  ],

  // workspace buttons
  "sway/workspaces": {
    "all-outputs": true,
    "disable-scroll": true,
    "format": "{icon}",
    "format-icons": {
      "focused": "яМГ"
      // "focused": "ЁЭЭ║"
    }
  },

  "sway/window#app-id": {
    "icon": false,
    "format": "[ {app_id} ]"
  },

  "sway/window#app-title": {
    "icon": false,
    "format": "{title}",
    "rewrite": {
      "(.*) - Chromium": "$1",
      "(.*) тАФ Mozilla Firefox": "$1",
      "(.*) - VLC media player": "$1"
    }
  },

  // sway mode - resize, default, etc
  "sway/mode": {
    "format": "{}"
  },

  // system updates
  "custom/pacman": {
    "signal": 8,
    "format": " [ {} тЦ▓ ] ",
    "interval": 3600, // seconds
    "exec": "checkupdates | wc --lines",
    "exec-if": "checkupdates"
  },

  // lock/unlocked
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "яа╛",
      "deactivated": "яДа"
    }
  },

  "cpu": {
    "tooltip": true,
    "format": "{usage}% яЛЫ",
    "states": {
      "good": 16,
      "warning": 32,
      "critical": 64
    }
  },

  "memory": {
    "tooltip": true,
    "format": "{percentage}% яФ╕ {swapPercentage}% яФ╕",
    "tooltip-format": "{percentage}% яФ╕ memory {used}GB / {total}GB \n{swapPercentage}% яГЙ swap {swapUsed}GB / {swapAvail}GB",
    "states": {
      "good": 32,
      "warning": 64,
      "critical": 80
    }
  },

  "disk": {
    "path": "/",
    "interval": 420,
    "format": "{percentage_used}% яВа",
    "states": {
      "critical": 75
    }
  },

  "disk#disk-home": {
    "path": "/home",
    "disk": "disk-home",
    "interval": 420,
    "format": "{percentage_used}% яВа",
    "states": {
      "critical": 75
    }
  },

  "temperature": {
    "tooltip": true,
    "critical-threshold": 55,
    "format": "{temperatureC}┬░C"
  },

  // display brightness
  "backlight": {
    "format": "{percent}^"
  },

  "pulseaudio": {
    "max-volume": 100,
    "scroll-step": 5.0,
    "on-click": "pavucontrol",
    "format": "{volume}% {icon} {format_source}",
    "format-muted": "яЪй {format_source}",
    "format-source": "{volume}% яД░",
    "format-source-muted": "яД▒",
    "format-bluetooth": "{volume}% {icon}яКФ {format_source}",
    "format-bluetooth-muted": "яЪй {icon}яКФ {format_source}",
    "format-icons": {
      "headphone": "яАе",
      "hands-free": "яЦР",
      "headset": "яЦР",
      "phone": "яВХ",
      "portable": "яВХ",
      "car": "яЖ╣",
      "default": ["яАж", "яАз", "яАи"]
    }
  },

  "sway/scratchpad#count": {
    "tooltip": true,
    "show-empty": false,
    "format": "{count}",
    "tooltip-format": "[ {app} ] {title}"
  },

  "sway/scratchpad#icon": {
    "tooltip": true,
    "show-empty": true,
    "format": "{icon}",
    "format-icons": ["яЛТ", "яЛТ"], // empty, non-empty icon
    "tooltip-format": "[ {app} ] {title}"
  },

  "battery": {
    "states": {
      "good": 80,
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-alt": "{time} {icon}",
    "format-plugged": "{capacity}% яЗж",
    "format-charging": "{capacity}% яЧз",
    "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
  },

  "network": {
    // "interface": "wlp2*", // (Optional) To force the use of this interface
    "format-wifi": "{essid} яЗл",
    "format-ethernet": "{ifname}: {ipaddr}/{cidr} яЮЦ",
    "format-linked": "{ifname} (No IP) яЮЦ",
    "format-disconnected": "Disconnected тЪа",
    "format-alt": "{ifname}: {ipaddr}/{cidr} яЮЦ",
    "tooltip-format-wifi": "{essid} [ {signalStrength}% ] яЗл"
  },

  "clock": {
    "format": "{:%H:%M}",
    "format-alt": "{:%d.%m.%Y}",
    "tooltip-format": "<tt>{calendar}</tt>",
    "calendar": {
      "mode": "month",
      "format": {
        "today": "<span color='#ff6699'><b>{}</b></span>",
        "weekdays": "<span color='#99ffdd'><b>{}</b></span>"
      }
    }
  },

  "sway/language": {
    "tooltip": true,
    "format": "{flag}",
    "tooltip-format": "{flag} {long}",
    "on-click": "swaymsg input type:keyboard xkb_switch_layout next"
  },

  // hidden if no apps in tray
  "tray": {
    "spacing": 10,
    "icon-size": 16
  },

  "custom/arch": {
    "format": "яМГ"
  },

  "custom/right-arrow": {
    "format": " яГЪ "
  }
}
