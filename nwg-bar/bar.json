[
  {
    "label": "Lock",
    "exec": "hyprlock",
    "exec-sway": "swaylock -f -F -e -k -l -c 333333 -i ~/dev/wallpapers/arch-lock.png",
    "icon": "/usr/share/nwg-bar/images/system-lock-screen.svg"
  },
  {
    "label": "Logout",
    "exec": "hyprctl dispatch exit",
    "exec-sway": "swaymsg exit",
    "icon": "/usr/share/nwg-bar/images/system-log-out.svg"
  },
  {
    "label": "Reboot",
    "exec": "systemctl reboot",
    "icon": "/usr/share/nwg-bar/images/system-reboot.svg"
  },
  {
    "label": "Shutdown",
    "exec": "systemctl --ignore-inhibitors poweroff",
    "icon": "/usr/share/nwg-bar/images/system-shutdown.svg"
  }
]
